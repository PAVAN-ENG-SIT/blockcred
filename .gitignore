# ========================
# BlockCred Root .gitignore
# ========================

# --- Environment & Secrets ---
.env
.env.local
.env.production
.env.*.local

# --- Python Backend ---
backend/venv/
backend/__pycache__/
backend/app/__pycache__/
backend/app/**/__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# --- Node.js Frontend ---
frontend/node_modules/
frontend/.next/
frontend/out/

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Misc ---
*.log
npm-debug.log*
